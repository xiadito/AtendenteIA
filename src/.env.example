# ==========================================================================
# .env.example — copie para .env e preencha com valores reais.
# NUNCA faça commit do .env real (contém segredos).
# Todas as variáveis são lidas em src/config.py via python-dotenv.
# ==========================================================================

# --- Database -------------------------------------------------------------
# URL de conexão Postgres. Formato: postgresql://user:senha@host:porta/banco
DATABASE_URL="postgresql://postgres:senha@localhost:5432/mercadinho_dev"

# --- WhatsApp (Meta Cloud API — transição futura, hoje inativo) -----------
WHATSAPP_TOKEN="EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WHATSAPP_PHONE_NUMBER_ID="000000000000000"
# Token de verificação do webhook Meta (GET /webhook)
VERIFY_TOKEN="mercadinhoBot"

# --- Flask ----------------------------------------------------------------
# Segredo de sessão (obrigatório para a auth do dashboard). Use um valor longo e aleatório.
FLASK_SECRET_KEY="troque-por-um-valor-aleatorio-longo"
FLASK_ENV="development"

# --- Twilio (WhatsApp Sandbox — dev/testes) -------------------------------
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_SANDBOX_NUMBER="whatsapp:+14155238886"
# Código de recuperação da conta Twilio (guardado aqui por conveniência; não é lido pelo app)
RECOVERY_CODE_TWILIO="XXXXXXXXXXXXXXXXXXXXXXXX"

# --- AI Service (OLLAMA em dev | CLAUDE em produção) -----------------------
# Dev (Ollama):   AI_BASE_URL=http://localhost:11434/v1
# Prod (Claude):  AI_BASE_URL=https://api.anthropic.com/v1/
AI_BASE_URL="https://api.anthropic.com/v1/"
AI_MODEL="claude-haiku-4-5-20251001"
AI_API_KEY="sk-ant-apiXX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- Dashboard ------------------------------------------------------------
DASHBOARD_USER="admin"
DASHBOARD_PASSWORD="troque-esta-senha"

# --- Google Calendar OAuth 2.0 (Módulo 1 — onboarding) --------------------
# Credenciais tipo "Aplicativo da Web" geradas no Google Cloud Console.
GOOGLE_CLIENT_ID="xxxxxxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxx"
# Deve ser IDÊNTICO (caractere a caractere) ao URI cadastrado no Google Cloud Console.
# Atenção: localhost e 127.0.0.1 são tratados como URIs DIFERENTES pelo Google.
GOOGLE_REDIRECT_URI="http://localhost:5000/integrations/google/callback"
